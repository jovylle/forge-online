# Owner-only auth
FORGE_OWNER_USERNAME=your-username
# Generate with: npm run hash-password -- "your-password"
FORGE_OWNER_PASSWORD_HASH=$2b$12$replace_this_with_a_bcrypt_hash
SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# GitHub sync
GITHUB_USERNAME=your-github-username
# Optional. When omitted, Forge Online syncs public owned repositories only.
GITHUB_TOKEN=

# Supabase server-side metadata storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
